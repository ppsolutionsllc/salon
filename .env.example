# PostgreSQL Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=salon_db

# FastAPI Config
SECRET_KEY=change-me-min-32-chars
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:4000
TRUSTED_HOSTS=localhost,127.0.0.1
SEED_NETWORK_ADMIN_EMAIL=admin
SEED_NETWORK_ADMIN_PASSWORD=admin12345

# Next.js Config
API_INTERNAL_URL=http://api:8000
INTERNAL_API_URL=http://api:8000
API_PUBLIC_URL=http://localhost:4000/api
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=change-me-min-32-chars
AUTH_TRUST_HOST=true
NEXT_PUBLIC_ENABLE_SW=false

# Update System (CRM Settings page)
NEXT_PUBLIC_UPDATE_SYSTEM=github_actions
NEXT_PUBLIC_DEPLOY_BRANCH=main
NEXT_PUBLIC_AUTO_DEPLOY_ON_PUSH=true
NEXT_PUBLIC_DEPLOY_WORKFLOW_NAME=Deploy To Server
# Optional: direct link to GitHub Actions workflow (displayed in CRM settings)
NEXT_PUBLIC_GITHUB_ACTIONS_URL=https://github.com/your-org/your-repo/actions/workflows/deploy.yml

# Deploy/rollback scripts
WEB_EXTERNAL_PORT=8080
HEALTHCHECK_PORT=8080
DB_BACKUP_KEEP=20
UPLOADS_BACKUP_KEEP=10
