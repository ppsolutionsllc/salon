# Runtime mode
ENVIRONMENT=production
WEB_EXTERNAL_PORT=8080

# Public domain (behind Nginx Proxy Manager)
AUTH_URL=https://aestheticsprime.beauty
NEXTAUTH_URL=https://aestheticsprime.beauty
NEXT_PUBLIC_SITE_URL=https://aestheticsprime.beauty
NEXT_PUBLIC_APP_URL=https://aestheticsprime.beauty
NEXT_PUBLIC_API_URL=/api
AUTH_TRUST_HOST=true

# Internal API service URL (Docker network)
API_INTERNAL_URL=http://api:8000
INTERNAL_API_URL=http://api:8000
API_PUBLIC_URL=https://aestheticsprime.beauty/api

# Security secrets (generate unique values)
AUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_SECRET=replace-with-long-random-secret
SECRET_KEY=replace-with-long-random-secret

# API proxy/security
CORS_ORIGINS=https://aestheticsprime.beauty
TRUSTED_HOSTS=aestheticsprime.beauty,localhost,127.0.0.1,api
SITE_EDITOR_OPERATOR_WRITE=false

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-db-password
POSTGRES_DB=salon_db

# Seed admin
SEED_NETWORK_ADMIN_EMAIL=admin@aestheticsprime.beauty
SEED_NETWORK_ADMIN_PASSWORD=replace-admin-password

# Deploy scripts
HEALTHCHECK_PORT=8080
WAIT_FOR_SERVICES_RETRIES=40
WAIT_FOR_SERVICES_DELAY=2
DB_BACKUP_KEEP=20
UPLOADS_BACKUP_KEEP=10
NEXT_PUBLIC_SITE_EDITOR_OPERATOR_WRITE=false

# Optional CRM "updates" link
NEXT_PUBLIC_GITHUB_ACTIONS_URL=https://github.com/your-org/your-repo/actions/workflows/deploy.yml
